AUTH_SECRET=
AUTH_URL=http://localhost:3000
GMAIL_USER=
GMAIL_APP_PASSWORD=
EMAIL_FROM=AgentGuard <your-gmail-address@gmail.com>
AWS_REGION=us-east-1
AWS_ROLE_ARN=
DYNAMODB_USERS_TABLE=
DYNAMODB_API_KEYS_TABLE=
DYNAMODB_SCANS_TABLE=
DYNAMODB_USAGE_TABLE=
DYNAMODB_AUTH_TABLE=
DYNAMODB_PLATFORM_TABLE=
S3_BUCKET_NAME=
SQS_QUEUE_URL=
# Detector provider: auto, openai, openrouter, or aws
PROVIDER_MODE=auto
# Direct provider credentials stay server-side. In auto mode OpenAI is tried first.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
# Create a key at https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-5.6
# Required for encrypted workspace BYOK values; use a long random secret
PROVIDER_KEY_ENCRYPTION_SECRET=
# Real DeBERTa activation probe. Use either a direct token or a Secrets Manager ARN.
OPENAI_SECRET_ID=
PROBE_SERVICE_URL=
PROBE_SERVICE_TOKEN=
PROBE_TOKEN_SECRET_ID=
PROBE_MODEL=protectai/deberta-v3-base-prompt-injection-v2
API_RATE_LIMIT_PER_MINUTE=60
