{
  "name": "agentguard-openclaw",
  "version": "0.1.0",
  "description": "Fail-closed AgentGuard security hooks for OpenClaw workflows",
  "type": "module",
  "license": "MIT",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "prepack": "pnpm build"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.7.1-0",
      "minGatewayVersion": "2026.7.1-0"
    },
    "build": {
      "openclawVersion": "2026.7.1-2",
      "pluginSdkVersion": "2026.7.1-2"
    },
    "install": {
      "npmSpec": "agentguard-openclaw",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.7.1-0"
    }
  },
  "peerDependencies": {
    "openclaw": ">=2026.7.1-0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "openclaw": "2026.7.1-2",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
