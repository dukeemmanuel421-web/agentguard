{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentguard.example/schemas/injection-benchmark-v1.json",
  "title": "AgentGuard injection benchmark dataset",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "datasetVersion", "name", "description", "cases"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": "1" },
    "datasetVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "cases": {
      "type": "array",
      "minItems": 20,
      "items": { "$ref": "#/$defs/case" }
    }
  },
  "$defs": {
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "category",
        "title",
        "text",
        "source",
        "expectedBlocked",
        "tags",
        "rationale"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^inj-v[0-9]+-[0-9]{3}$"
        },
        "category": {
          "enum": ["attack", "benign", "borderline"]
        },
        "title": { "type": "string", "minLength": 1, "maxLength": 120 },
        "text": { "type": "string", "minLength": 1, "maxLength": 50000 },
        "source": {
          "enum": [
            "USER_PROMPT",
            "TRUSTED_TOOL",
            "TOOL_OUTPUT",
            "WEB_PAGE",
            "DOCUMENT",
            "MCP_OUTPUT",
            "UNKNOWN"
          ]
        },
        "expectedBlocked": { "type": "boolean" },
        "tags": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          }
        },
        "rationale": { "type": "string", "minLength": 1, "maxLength": 500 }
      }
    }
  }
}
